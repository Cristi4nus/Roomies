<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="Roomies.PaginaChat"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml">

    <Grid RowDefinitions="*, Auto" Padding="10">

        <ScrollView x:Name="scrollView" Grid.Row="0">
            <VerticalStackLayout x:Name="MessagesContainer" Spacing="5"/>
        </ScrollView>

        <HorizontalStackLayout Grid.Row="1" Spacing="10" VerticalOptions="End">
            <Button Text="pin"
                    Clicked="OnSendLocationClicked"
                    WidthRequest="50"/>

            <Button Text="Trimite"
                    Clicked="OnSendClicked"
                    WidthRequest="80"/>

            <Entry x:Name="MessageEntry"
                   Placeholder="Scrie un mesaj..."
                   HorizontalOptions="FillAndExpand"
                   WidthRequest="250"/>
        </HorizontalStackLayout>

    </Grid>

</ContentPage>