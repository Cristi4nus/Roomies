<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Roomies.UserLoginPage"
             Title="Autentificare">

    <VerticalStackLayout Padding="20" Spacing="15">

        <Entry x:Name="InputEmail" Placeholder="Email" Keyboard="Email" />
        <Entry x:Name="InputParola" Placeholder="Parolă" IsPassword="True" />

        <Button Text="Login"
                Clicked="OnLoginClicked"
                BackgroundColor="#2B0B98"
                TextColor="White"
                CornerRadius="10" />
        <Button Text="Sign Out/Create a new profile"
                BackgroundColor="#2B0B98"
                TextColor="White"
                CornerRadius="10"
                Clicked="OnSignOutClicked" />

    </VerticalStackLayout>
</ContentPage>
